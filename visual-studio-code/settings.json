{
	"cmake.cmakePath": "/usr/bin/cmake",
	"debug.internalConsoleOptions": "openOnSessionStart",
	"debug.openDebug": "openOnDebugBreak",
	"diffEditor.experimental.showMoves": true,
	"diffEditor.ignoreTrimWhitespace": false,
	"diffEditor.renderSideBySide": false,
	"docker.dockerPath": "/usr/bin",
	"git.autofetch": true,
	"git.autoStash": true,
	"git.enableSmartCommit": true,
	"git.mergeEditor": true,
	"git.showPushSuccessNotification": true,
	"git.supportCancellation": true,
	"git.timeline.showUncommitted": true,
	"git.verboseCommit": true,
	"githubPullRequests.defaultCreateOption": "createDraft",
	"githubPullRequests.fileListLayout": "tree",
	"githubPullRequests.notifications": "pullRequests",
	"githubPullRequests.showPullRequestNumberInTree": true,
	"makefile.makePath": "/usr/bin",
	"rust-analyzer.server.path": "/usr/bin/rust/rust-analyzer-preview/bin",
	"security.workspace.trust.startupPrompt": "always",
	"telemetry.telemetryLevel": "off",
	"zig.formattingProvider": "off",
	"zig.initialSetupDone": true,
	"zig.path": "zig",
	"zig.zls.path": "zls"
}