" Background Theme
set background=dark

" Encoding
set encoding=utf-8

" Show Emojis
set emoji

" File Synchronization
set fsync

" Show Status Bar
set laststatus=2

" Load Plugins
set loadplugins

" Show Special Characters
set magic

" Show more-prompt
set more

" Mouse Support
set mouse=nvi

" Show Line Numbers
set number

" Runtime Path
set runtimepath=/usr/bin/nvim/share/nvim/runtime/*.vim

" Shell Path
set shell=/usr/bin/bash

" Show Command Output
set showcmd

" Show Command Lines of Code
set showcmdloc=last

" Show Mode
set showmode

" Show Tab Line
set showtabline=1

" Spelling Check
set spell

" Spelling Suggestion
set spellsuggest=best

" Terminal Color
set termguicolors

" Show Window Title
set title

" Show Visual Bell
set visualbell

" Show Warnings
set warn

" Show Wild Menu
set wildmenu

" Full Wild Mode
set wildmode=full

" Wrap Text
set wrap

" Wrap Scan
set wrapscan

" Enable File Writing
set write

" Enable File Writing Backups
set writebackup
